# ---- App ----
NEXT_PUBLIC_APP_URL=http://localhost:3000
# 32+ char passphrase; used to AES-256-GCM encrypt stored credentials at rest.
# CHANGING THIS makes all previously-encrypted secrets/tokens undecryptable.
APP_ENCRYPTION_KEY=

# ---- Supabase ----
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ---- Google OAuth / YouTube ----
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/api/auth/google/callback
# scopes: youtube.upload youtube.readonly yt-analytics.readonly

# ---- YouTube publishing ----
YOUTUBE_PRIVACY=public              # public | private | unlisted
YOUTUBE_PUBLISH_AT=                 # ISO time to schedule (forces private until then)
YOUTUBE_CATEGORY_ID=24              # 24=Entertainment, 27=Education, 28=Science&Tech
YOUTUBE_MADE_FOR_KIDS=false
YOUTUBE_PLAYLIST_ID=
YOUTUBE_DAILY_QUOTA=10000           # default project quota; ~6 uploads/day

# ---- OpenAI ----
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_IMAGE_MODEL=dall-e-3
OPENAI_IMAGE_SIZE=1024x1792
OPENAI_VISION_MODEL=gpt-4o

# ---- Creative optimization (Phase 5) ----
VIRAL_GATE=80            # re-optimize until viral score >= this (max 3 cycles)
CREATIVE_HOOKS=5
CREATIVE_TITLES=10
CREATIVE_DESCRIPTIONS=3
THUMBNAIL_VARIANTS=5     # image-gen calls per video — main cost driver

# ---- Rendering (worker container: needs ffmpeg + chromium) ----
RENDER_VIDEO_BITRATE=12M
MUSIC_URL=

# ---- ElevenLabs ----
ELEVENLABS_API_KEY=
ELEVENLABS_MODEL=eleven_multilingual_v2
ELEVENLABS_VOICE_ID_EN=
ELEVENLABS_VOICE_ID_HI=

# ---- Trend discovery ----
TRENDS_GEO=US
RSS_FEEDS=

# ---- Pipeline ----
DAILY_TOPIC_COUNT=3          # distinct topics/day. Total videos = this × languages (EN+HI)
                             # ⚠ 3 topics × 2 langs = 6 uploads ≈ YouTube daily quota ceiling

# ---- Cloudflare R2 ----
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_URL=

# ---- External data sources ----
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
NEWS_API_KEY=
YOUTUBE_DATA_API_KEY=

# ---- Render worker ----
WORKER_SHARED_SECRET=

# ---- Analytics & notifications (Phase 6) ----
NOTIFY_WEBHOOK_URL=          # optional: POST notifications here (Slack/Discord/etc.)
NOTIFY_CTR_DROP=2            # notify if CTR falls this many points
NOTIFY_RETENTION_DROP=10     # notify if retention % falls this much
NOTIFY_QUOTA_LOW=8000        # notify when daily Data API units used exceeds this

# ---- Orchestration & scheduler (Phase 7) ----
APP_URL=http://localhost:3000
TICK_INTERVAL_MS=15000       # how often the scheduler drains the queue
DISPATCH_HOUR_UTC=6          # hour to enqueue the daily run
QUEUE_BACKOFF_BASE_MS=2000
QUEUE_BACKOFF_CAP_MS=300000

# ---- Cost estimates (USD; override to match your billing) ----
COST_CHAT=0.01
COST_IMAGE=0.08
COST_VISION=0.01
COST_VOICE_PER_1K=0.30
COST_STORAGE=0.005
COST_RENDER=0.02

# ---- Observability (optional; wiring is a TODO — see CONTINUE.md) ----
SENTRY_DSN=
